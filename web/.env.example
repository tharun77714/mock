# Copy to .env.local and fill in values (never commit .env.local)

MONGODB_URI=
JWT_SECRET=
NEXT_PUBLIC_VAPI_WEB_TOKEN=
NEXT_PUBLIC_VAPI_WORKFLOW_ID=
# FREE interview-context LLM (tried first). Get a key at https://console.groq.com/keys — uses same `openai` Python package.
GROQ_API_KEY=
# Optional (default llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Paid optional fallback
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: Storage uploads (Settings → API → service_role). Do not expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: bucket name (default: interviews)
# SUPABASE_INTERVIEWS_BUCKET=interviews

# FastAPI URL (Next.js calls this for /process)
PYTHON_API_URL=http://localhost:8000

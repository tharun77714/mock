# MockMate Web Frontend - Environment Variables
# Copy this file to .env.local and fill in your actual credentials
# NEVER commit .env.local to git! It's already in .gitignore

# ─── Database (Shared with Backend) ────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/mockmate?retryWrites=true&w=majority

# ─── Authentication ────────────────────────────────────────────────
# Generate random secret with: openssl rand -base64 32
JWT_SECRET=generate-a-secure-random-secret-in-production
NEXTAUTH_SECRET=generate-a-secure-random-secret-in-production
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth (Sign-in with Google) ────────────────────────────
# Create OAuth app at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# ─── Groq API (Resume Intelligence & Interview Analysis) ───────────
# FREE LLM API - Get key from https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here
# Optional: specify model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenAI (Optional Fallback) ────────────────────────────────────
# Paid alternative if Groq is unavailable
# Get key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# ─── Vapi AI (Voice Interview Workflow) ────────────────────────────
# Configure at https://vapi.ai/dashboard
NEXT_PUBLIC_VAPI_WEB_TOKEN=your-vapi-web-token-here
NEXT_PUBLIC_VAPI_WORKFLOW_ID=your-vapi-workflow-id-here

# ─── Supabase Cloud Storage ────────────────────────────────────────
# Create project at https://supabase.com/
# These are PUBLIC keys - safe to expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# WARNING: Keep these SECRET - server-side only!
# Do NOT expose SUPABASE_SERVICE_ROLE_KEY to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: customize bucket name (default: interviews)
# SUPABASE_INTERVIEWS_BUCKET=interviews

# ─── GitHub OAuth (Optional) ────────────────────────────────────────
# Create OAuth app at https://github.com/settings/developers
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Guest Mode (Optional - for demo purposes) ─────────────────────
# Enable unauthenticated demo access. Generate random string with: openssl rand -base64 16
# NEXT_PUBLIC_GUEST_SECRET=your-guest-secret-here
# GUEST_SECRET=your-guest-secret-here

# ─── FastAPI Backend URL ──────────────────────────────────────────
# URL where your Python FastAPI backend is running
PYTHON_API_URL=http://localhost:8000
